POSTGRES_USER=training
POSTGRES_PASSWORD=training_secret
POSTGRES_DB=training_app
DATABASE_URL=postgresql+asyncpg://training:training_secret@postgres:5432/training_app
XAI_API_KEY=your-xai-api-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning

# Auth — generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed frontend origins (production URLs)
# Example: ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=http://localhost:5173
